# CuidaCare — exemplo de variáveis de ambiente (seção 2.6.9)
# Copie este arquivo para ".env" e ajuste os valores. O .env NÃO é versionado.

# development | staging | production
ENVIRONMENT=development

# Chave secreta do Django (gere uma nova em produção)
SECRET_KEY=troque-esta-chave-em-producao

ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados PostgreSQL (apenas em produção)
DB_NAME=cuidacare_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# E-mail — recuperação de senha
# Em desenvolvimento, deixe em branco para usar o console (e-mail impresso no terminal).
# Para envio real via Gmail, use uma "senha de app" (não a senha normal da conta):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=CuidaCare <seu-email@gmail.com>
